# event-shortener configuration
# Copy to .env and adjust. In docker-compose these are injected by the stack.

# asyncpg URL for the service's own PostgreSQL (pg-shortener).
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@pg-shortener:5432/event_shortener

# Static bearer key gating every /api/v1/* route (constant-time compared).
# Must match the value event-booking sends as SHORTENER_API_KEY.
SHORTENER_API_KEY=dev-shortify-api-key-8c4e1f7b2a93d650

# Logging
LOG_LEVEL=INFO
DEBUG=false
